local app = require("config.neovim_dev").app
local file_exists = require("yabs.conditions").file_exists

local function all(...)
    local conditions = { ... }

    return function()
        for _, cond in ipairs(conditions) do
            if not cond() then
                return false
            end
        end

        return true
    end
end

return {
    ["npx tsc"] = {
        command = function()
            app("npx", { "tsc" })
        end,

        condition = all(
            file_exists("package.json"),
            file_exists("tsconfig.json")
        ),

        type = "lua",
    },

    ["npm test"] = {
        command = function()
            app("npm", { "test" })
        end,

        condition = all(
            file_exists("package.json"),
            file_exists("tsconfig.json")
        ),

        type = "lua",
    },
}
